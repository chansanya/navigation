# Local Cloudflare Pages Functions variables.
# Keep real secrets in .dev.vars. Do not commit .dev.vars.

ADMIN_TOKEN=change-me-admin-token
PRIVATE_PASSWORD=change-me-private-password

# Optional: enable Cloudflare Pages/Workers project sync in the admin UI.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Optional: enable MyApp personal records sync.
MYAPP_BASE_URL=
MYAPP_EXPORT_KEY=
MYAPP_PAYLOAD_KEY_PREFIX=myapp-export-payload-v1:
MYAPP_SYNC_SOURCE=navigation
